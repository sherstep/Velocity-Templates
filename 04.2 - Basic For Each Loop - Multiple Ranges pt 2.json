    "softwareType": "IOS",
    "softwareVariant": "XE",
    "templateContent": "## Configuring Access Ports with Basic For-Each Loop ##\n\n## 1. Initialize an empty list\n#set($InterfaceRangeList = [])\n\n## 2. Check each range and add only if valid (not 0)\n#if($Range1Start != 0 && $Range1End != 0)\n    #set($void = $InterfaceRangeList.add([$Range1Start..$Range1End]))\n#end\n\n#if($Range2Start != 0 && $Range2End != 0)\n    #set($void = $InterfaceRangeList.add([$Range2Start..$Range2End]))\n#end\n\n#if($Range3Start != 0 && $Range3End != 0)\n    #set($void = $InterfaceRangeList.add([$Range3Start..$Range3End]))\n#end\n\n#if($Range4Start != 0 && $Range4End != 0)\n    #set($void = $InterfaceRangeList.add([$Range4Start..$Range4End]))\n#end\n\n## Iterate through each range, then through each integer in that range\n#foreach($range in $InterfaceRangeList)\n#foreach($access_port in $range)\ninterface ${access-port-speed}1/0/$access_port\ndescription Access Port\nswitchport mode access\nswitchport access vlan 200\nswitchport voice vlan 20\nspanning-tree portfast\nspanning-tree bpduguard enable\nspanning-tree guard root\n\n#end\n#end\n\n\n",
