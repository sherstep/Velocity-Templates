[
  {
    "name": "05.1 - Multiple For Each Loops - with Single Stack Range",
    "description": "",
    "tags": [],
    "author": "sherwyn",
    "deviceTypes": [
      {
        "productFamily": "Switches and Hubs"
      }
    ],
    "softwareType": "IOS",
    "softwareVariant": "XE",
    "templateContent": "## Configure multiple ranges of trunk ports for all switches in stack ##\n#foreach($stack_number in [${first-stack-number}..${end-stack-number}])\n#foreach($trunkrange in [[$TrunkRange1Start..$TrunkRange1End],[$TrunkRange2Start..$TrunkRange2End]])\n#foreach($trunk_port in $trunkrange)\ninterface ${trunk_interface_type}${stack_number}/1/$trunk_port\ndescription Uplink port\nswitchport mode trunk\nswitchport trunk allowed vlan 20,100,200,300,400\n\n#end\n#end\n#end\n\n## Configure multiple ranges of access ports for all switches in stack##\n## Iterate through each range, then through each integer in that range\n#foreach($stack_number in [${first-stack-number}..${end-stack-number}])\n#foreach($range in [[$Range1Start..$Range1End],[$Range2Start..$Range2End],[$Range3Start..$Range3End],[$Range4Start..$Range4End]])\n#foreach($access_port in $range)\ninterface ${acess-port-speed}${stack_number}/0/$access_port\ndescription Access Port\nswitchport mode access\nswitchport access vlan 200\nswitchport voice vlan 20\nspanning-tree portfast\nspanning-tree bpduguard enable\nspanning-tree guard root\n\n#end\n#end\n#end",
