[
  {
    "name": "13.1 - EEM Script - CDP Rename - Append Description",
    "description": "",
    "tags": [],
    "author": "sherstep",
    "deviceTypes": [
      {
        "productFamily": "Switches and Hubs"
      }
    ],
    "softwareType": "IOS",
    "softwareVariant": "XE",
    "templateContent": "event manager applet updateport\nevent neighbor-discovery interface regexp .* cdp add\n\naction 1.0 cli command \"enable\"\naction 2.0 cli command \"show interface $_nd_local_intf_name | include ^[\\ ]*[Dd]escription\"\naction 3.0 regexp \"^[ ]*[Dd]escription:[ ]*(.*)\" \"$_cli_result\" match current_desc\naction 3.1 if $_regexp_result ne \"1\"\naction 3.2 set current_desc \"No Existing Description\"\naction 3.3 end\naction 4.0 cli command \"config t\"\naction 5.0 cli command \"interface $_nd_local_intf_name\"\naction 6.0 cli command \"description CDP - $_nd_cdp_platform. Desc - $current_desc\"\naction 7.0 cli command \"end\"\n\n## Clean up EEM scripts ##\nevent manager applet clearcdptable\nevent none maxrun 120\naction 1.0 cli command \"enable\"\naction 2.0 cli command \"clear cdp table\"\naction 3.0 wait 60\naction 4.0 cli command \"enable\"\naction 5.0 cli command \"config t\"\naction 6.0 cli command \"no event manager applet updateport\"\naction 6.1 cli command \"no event manager applet clearcdptable\"\naction 7.0 cli command \"end\"\n\n\n#MODE_ENABLE\nevent manager run clearcdptable\n#MODE_END_ENABLE\n\n\n",
