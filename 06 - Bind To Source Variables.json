    "softwareType": "IOS",
    "softwareVariant": "XE",
    "templateContent": "## Configure trunk ports using bind-to-source variable ##\n## Choose specific trunk ports based on device  ##\n#foreach($trunk_port in ${trunk_port})\ninterface $trunk_port\ndescription Uplink port\nswitchport mode trunk\nswitchport trunk allowed vlan 20,100,200,300,400\n\n#end\n\n## Configure multiple ranges of access ports ##\n## Iterate through each range, then through each integer in that range\n#foreach($range in [[$Range1Start..$Range1End],[$Range2Start..$Range2End],[$Range3Start..$Range3End],[$Range4Start..$Range4End]])\n#foreach($access_port in $range)\ninterface ${acess-port-speed}1/0/$access_port\ndescription Access Port\nswitchport mode access\nswitchport access vlan 200\nswitchport voice vlan 20\nspanning-tree portfast\nspanning-tree bpduguard enable\nspanning-tree guard root\n\n#end\n#end",
